{
  "hosting": {
    "public": "public",
    "cleanUrls": true,
    "rewrites": [
      {
        "source": "/getAllPosts",
        "function": "mlw_app"
      },
      {
        "source": "/getRecentPosts",
        "function": "mlw_app"
      },
      {
        "source": "/getPost/**",
        "function": "mlw_app"
      },
      {
        "source": "/post/**",
        "destination": "/post.html"
      },
      {
        "source": "/getAllBooks",
        "function": "mlw_app"
      },
      {
        "source": "/getAllStandaloneBooks",
        "function": "mlw_app"
      },
      {
        "source": "/getAllSeries",
        "function": "mlw_app"
      },
      {
        "source": "/getBook/**",
        "function": "mlw_app"
      },
      {
        "source": "/book/**",
        "destination": "/book.html"
      },
      {
        "source": "**",
        "function": "mlw_app"
      }
    ],
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ]
  },
  "functions": [
    {
      "source": "functions",
      "codebase": "default",
      "ignore": [
        "node_modules",
        ".git",
        "firebase-debug.log",
        "firebase-debug.*.log",
        "*.local"
      ]
    }
  ]
}
