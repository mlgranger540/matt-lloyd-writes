{
    "hosting": {
        "public": "public",
        "cleanUrls": true,
        "rewrites": [
            {
                "source": "/post/**",
                "destination": "/post.html"
            },
            {
                "source": "/getPost/**",
                "function": "mlw_app"
            },
            {
                "source": "/getPosts",
                "function": "mlw_app"
            },
            {
                "source": "/getAllBookDetails",
                "function": "mlw_app"
            },
            {
                "source": "**",
                "function": "mlw_app"
            }],
        "ignore": [
            "firebase.json",
            "**/.*",
            "**/node_modules/**"
        ]
    },
    "functions": [
        {
            "source": "functions",
            "codebase": "default",
            "ignore": [
                "node_modules",
                ".git",
                "firebase-debug.log",
                "firebase-debug.*.log",
                "*.local"
            ]
        }
    ]
}
